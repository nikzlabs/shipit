FROM node:24-slim@sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d

RUN apt-get update && apt-get install -y git curl python3 make g++ ca-certificates gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Agent CLIs for local/dogfood mode (RUNTIME_MODE=local). Lockfile-pinned,
# integrity-verified install shared with the worker images (docs/141);
# canonical comment in Dockerfile.session-worker.prod. Now includes
# @playwright/mcp via the shared manifest, reconciling the prior prod/dev
# omission. `--ignore-scripts` blocks the dependency tree's postinstalls;
# `npm rebuild @anthropic-ai/claude-code` runs the install script for only that
# trusted package (native binary linker).
COPY docker/agent-cli/package.json docker/agent-cli/package-lock.json /opt/agent-cli/
RUN --mount=type=cache,target=/root/.npm \
    (cd /opt/agent-cli && npm ci --ignore-scripts && npm rebuild @anthropic-ai/claude-code)
ENV PATH="/opt/agent-cli/node_modules/.bin:${PATH}"

WORKDIR /app

# Install dependencies — source code is bind-mounted at runtime
COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci --prefer-offline --loglevel=verbose

# Workspace for user projects — each session creates its own git repo.
# Symlink Claude + Codex credential directories into /credentials so OAuth
# logins (Claude) and ChatGPT subscription logins (Codex) survive container
# restarts and idle cleanup. See docs/119-codex-subscription-auth/plan.md.
RUN mkdir -p /workspace /credentials \
 && ln -s /credentials/.claude /root/.claude \
 && ln -sf /credentials/.claude.json /root/.claude.json \
 && ln -s /credentials/.codex /root/.codex
VOLUME /workspace
VOLUME /credentials

COPY docker/docker-entrypoint.dev.sh /usr/local/bin/

# Bake in the secrets entrypoint wrapper (087-reusable-preview-secrets,
# Phase 1 follow-up). Mounted into compose service containers at
# `/shipit/secrets-entrypoint.sh` so they can pick up Docker secrets as env
# vars without modifying user code.
COPY docker/secrets-entrypoint.sh /usr/local/share/shipit/secrets-entrypoint.sh
RUN chmod 0755 /usr/local/share/shipit/secrets-entrypoint.sh

EXPOSE 3000 5173

CMD ["docker-entrypoint.dev.sh"]
