<?xml version="1.0" encoding="utf-8"?>
<!-- Full-bleed WebView. The old toolbar (an ~actionBarSize black bar that only
     hosted an overflow menu) is gone; reload is pull-to-refresh and Settings is
     a small translucent cog floating at top-center, away from the corners where
     ShipIt's own web UI keeps its controls. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/shipit_bg"
    android:fitsSystemWindows="true">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/web_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/shipit_bg" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="2dp"
        android:padding="6dp"
        android:alpha="0.45"
        android:background="@drawable/bg_settings_button"
        android:contentDescription="@string/menu_settings"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_settings" />

</FrameLayout>
