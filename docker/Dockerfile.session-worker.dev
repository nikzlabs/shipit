FROM node:24-slim

RUN apt-get update && apt-get install -y git curl python3 make g++ && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.npm npm install -g @anthropic-ai/claude-code @openai/codex

WORKDIR /app

COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci

COPY tsconfig.json ./
# Only copy code the session-worker actually needs — session + shared layers.
# Orchestrator and client code are not used and would bloat the image.
COPY src/server/session/ ./src/server/session/
COPY src/server/shared/ ./src/server/shared/

# Credential symlinks (same as dev/prod images)
RUN mkdir -p /workspace /credentials && ln -s /credentials/.claude /root/.claude && ln -sf /credentials/.claude.json /root/.claude.json

EXPOSE 9100

CMD ["node", "--import", "tsx", "src/server/session/session-worker.ts"]
