# ShipIt reverse proxy with basic auth.
#
# TLS is terminated by Cloudflare (proxy/orange-cloud mode).
# Caddy uses internal self-signed certs so Cloudflare can connect over HTTPS
# with SSL mode set to "Full".
#
# Set these environment variables (e.g. in /etc/caddy/environment):
#   SHIPIT_AUTH_USER  — username for basic auth
#   SHIPIT_AUTH_HASH  — bcrypt hash of your password
#
# Generate password hash:
#   caddy hash-password --plaintext 'your-password'

(auth) {
	basic_auth {
		{env.SHIPIT_AUTH_USER} {env.SHIPIT_AUTH_HASH}
	}
}

# Main app
shipit.example.com {
	tls internal
	import auth
	reverse_proxy localhost:4123
}

# Preview subdomains ({sessionId}--{port}.shipit.example.com)
*.shipit.example.com {
	tls internal
	import auth
	reverse_proxy localhost:4123
}
