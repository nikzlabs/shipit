FROM node:22-slim

# Install git, common build tools needed by npm packages with native deps
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      git \
      build-essential \
      python3 \
      ca-certificates \
      curl && \
    rm -rf /var/lib/apt/lists/*

# Install Claude CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Create app directory for worker code
WORKDIR /app

# Copy session worker bundle and dependencies.
# In production, this is the compiled JS + node_modules.
# For dev, mount the dist/ directory instead.
COPY dist/session-worker.js /app/
COPY node_modules /app/node_modules/

# Workspace will be bind-mounted at runtime
WORKDIR /workspace

# IPC server port — documented here for clarity.
# No EXPOSE needed since we use bridge networking.
EXPOSE 9100

CMD ["node", "/app/session-worker.js"]
