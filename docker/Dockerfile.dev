FROM node:24-slim

RUN apt-get update && apt-get install -y git curl python3 make g++ && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code @openai/codex

WORKDIR /app

# Install dependencies — source code is bind-mounted at runtime
COPY package.json package-lock.json ./
RUN npm ci

# Fallback git identity so commits always work; overridden per-repo when user sets identity
RUN git config --global user.name "ShipIt" && \
    git config --global user.email "shipit@local" && \
    git config --global commit.gpgsign false

# Workspace for user projects — each session creates its own git repo
RUN mkdir -p /workspace /credentials && ln -s /credentials/.claude /root/.claude && ln -sf /credentials/.claude.json /root/.claude.json
VOLUME /workspace
VOLUME /credentials

COPY docker/docker-entrypoint.dev.sh /usr/local/bin/

EXPOSE 3000 5173

CMD ["docker-entrypoint.dev.sh"]
