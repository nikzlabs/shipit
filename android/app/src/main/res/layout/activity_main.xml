<?xml version="1.0" encoding="utf-8"?>
<!-- Full-bleed WebView. The old toolbar (an ~actionBarSize black bar that only
     hosted an overflow menu) is gone; reload is long-press on the cog and
     Settings is a small translucent cog floating at top-center, away from the
     corners where ShipIt's own web UI keeps its controls.

     Pull-to-refresh (SwipeRefreshLayout) was removed: ShipIt's web UI scrolls
     inside inner containers, so the WebView document sits at scrollY == 0 and
     SwipeRefreshLayout.canChildScrollUp() reported "at top" for every downward
     swipe, stealing the gesture and making chat history unscrollable. The cog's
     long-press → reload is the Reload action (see docs/116 plan.md:40).

     Insets: targetSdk 35 forces edge-to-edge, so this root is laid out behind
     the status and nav bars. MainActivity applies the system-bar insets as
     padding on this FrameLayout in code (not android:fitsSystemWindows, which
     we removed for explicit control). The dark @color/shipit_bg fills the
     padded area so it still reads as full-bleed. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/shipit_bg">

    <WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/shipit_bg" />

    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="2dp"
        android:padding="6dp"
        android:alpha="0.45"
        android:background="@drawable/bg_settings_button"
        android:contentDescription="@string/menu_settings"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_settings" />

</FrameLayout>
