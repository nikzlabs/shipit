# ---- Build stage (install all deps including native addons) ----
FROM node:24-slim@sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d AS build

RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci --prefer-offline

COPY tsconfig.json ./
COPY src/server/session/ ./src/server/session/
COPY src/server/shared/ ./src/server/shared/
COPY scripts/build-mcp-bridges.mjs ./scripts/

# Precompile the internal stdio MCP bridges to self-contained plain-JS bundles
# (docs/199). Running them with `node` instead of `tsx <bridge>.ts` removes the
# ~1.5-2s per-spawn esbuild compile that, at the 0.5-CPU AGENT_DEFAULTS, made the
# permission bridge miss the Claude CLI's 2000ms MCP pre-wait and fail the turn.
# MUST run before the prune below — esbuild is a devDependency. The worker's
# resolveBridge() falls back to tsx-on-source when dist/mcp-bridges is absent.
RUN node scripts/build-mcp-bridges.mjs

# Prune devDependencies so we can copy a clean node_modules to prod
RUN --mount=type=cache,target=/root/.npm npm prune --omit=dev && npm install tsx

# ---- Production image ----
FROM node:24-slim@sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d

# SHI-194 — bake the pinned base-image digest into the runtime env. The overlay
# dep store keys its rolling base scope on THIS (the native-addon ABI surface),
# not the full worker-image id, so an app-code-only rebuild no longer rotates the
# scope (no per-deploy ~500 MB base churn, post-deploy installs stay warm).
# install-runtime.ts:runtimeKey() and overlay-session.ts:overlayRuntimeKey() read
# it; the orchestrator reads it back out of this image's env at startup. The ARG
# default MUST track the `FROM` digest above — a base bump changes both together,
# which is exactly what (and only what) rolls the scope. Keep them in sync.
ARG BASE_IMAGE_DIGEST=sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d
ENV BASE_IMAGE_DIGEST=${BASE_IMAGE_DIGEST}

# Runtime tools: git + curl for user projects, python3/make/g++ for native npm addons
# in user sessions (npm install inside /workspace may compile C/C++ addons),
# ripgrep (rg) because agents (Codex, Claude Code) prefer it for fast code search,
# bubblewrap (bwrap) because Codex probes for it on PATH at startup and logs an
# ERROR + configWarning when it's missing (falling back to its bundled copy).
# python3-pip + python3-venv let Python web projects (Streamlit, FastAPI, Gradio,
# Dash — see docs/168) create a venv and install deps; on Debian bookworm these
# are separate packages from python3, and PEP 668 means a global pip install is
# refused outside a venv, so a venv is the supported path.
# `gosu` (docs/150): the entrypoint runs as root only to prep the writable
# mounts, then drops to the unprivileged `shipit` user before exec'ing the
# worker. gosu is the Debian-native, no-TTY privilege-drop tool (su-exec is
# Alpine-only). It is intentionally NOT setuid — it relies on PID 1's
# CAP_SETUID/CAP_SETGID, which composes with `no-new-privileges`.
RUN apt-get update && apt-get install -y git curl python3 python3-pip python3-venv make g++ zip unzip ripgrep bubblewrap gosu && rm -rf /var/lib/apt/lists/*

# docs/150 §1 — rename the upstream `node` user (UID/GID 1000 in node:*-slim) to
# `shipit`. Reusing the existing 1000 account avoids a useradd collision and
# keeps a stable runtime UID with home /home/shipit.
RUN groupmod --new-name shipit node \
 && usermod --login shipit --move-home --home /home/shipit node \
 && chown -R shipit:shipit /home/shipit

# docs/150 §6 — npm's default global prefix (/usr/local) is root-owned, so
# `npm install -g` (MCP package installs, ad-hoc terminal CLIs) would EACCES as
# `shipit`. Redirect the global prefix and per-user cache into the runtime
# home, owned by `shipit`.
ENV NPM_CONFIG_PREFIX=/home/shipit/.npm-global
ENV PATH=/home/shipit/.npm-global/bin:${PATH}
RUN mkdir -p /home/shipit/.npm-global /home/shipit/.npm \
 && chown -R shipit:shipit /home/shipit/.npm-global /home/shipit/.npm

# Enable corepack so `pnpm` and `yarn` resolve on PATH. Node ships npm directly
# and bundles corepack, but corepack's shims aren't installed until `corepack
# enable` runs — without this, a repo on pnpm/yarn would fail any bare
# `pnpm install` / `yarn install` with command-not-found. ShipIt never picks the
# package manager: corepack reads each repo's `packageManager` field and fetches
# the pinned version, mirroring the lockfile-decides convention used for Python
# (uv/poetry/pip) below and the npm/yarn/pnpm download cache in
# container-lifecycle.ts. NOTE: corepack is bundled with Node 24
# but Node has signaled it may unbundle it in a future major — if a base-image
# bump removes it, replace this with an explicit `npm i -g pnpm yarn` install.
RUN corepack enable

# uv (Astral) — a single static binary that resolves/installs Python deps far
# faster than pip and reads uv.lock natively, so a repo standardized on uv "just
# works" without the agent bootstrapping a package manager. ShipIt provides the
# tool but never picks the winner: the project's lockfile decides (uv.lock → uv,
# poetry.lock → Poetry, requirements.txt → pip). See docs/168.
# TODO: pin like the agent CLIs once a Renovate policy covers it.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Agent CLIs: lockfile-pinned, integrity-verified, cooldown-aged install.
# See docs/141-cli-version-strategy. The versions live in
# docker/agent-cli/package.json and are byte-verified against
# docker/agent-cli/package-lock.json (not just by version string), so a deploy
# ships exactly what's committed — deterministic, auditable, git-revertable.
# `--ignore-scripts` blocks postinstall code-exec across the whole dependency
# tree (the usual supply-chain vector); `npm rebuild @anthropic-ai/claude-code`
# then runs the install script for ONLY that trusted package, which ships a
# native binary its postinstall links into place (codex and @playwright/mcp need
# no scripts). Version bumps are driven by the Renovate GitHub App (7-day
# cooldown via minimumReleaseAge) and gated on the CLI contract test — not by a
# deploy-time cache-bust. Bins land on PATH so the bare-name spawns in
# claude.ts / codex-adapter.ts / session-worker.ts (playwright-mcp) keep working.
COPY docker/agent-cli/package.json docker/agent-cli/package-lock.json /opt/agent-cli/
RUN --mount=type=cache,target=/root/.npm \
    (cd /opt/agent-cli && npm ci --ignore-scripts && npm rebuild @anthropic-ai/claude-code)
ENV PATH="/opt/agent-cli/node_modules/.bin:${PATH}"
RUN ln -sf /opt/agent-cli/node_modules/.bin/claude /usr/local/bin/claude \
 && ln -sf /opt/agent-cli/node_modules/.bin/codex /usr/local/bin/codex \
 && ln -sf /opt/agent-cli/node_modules/.bin/playwright-mcp /usr/local/bin/playwright-mcp

# Install Chrome and its system dependencies for Playwright MCP browser tools.
# Playwright MCP now defaults to the `chrome-for-testing` channel, so we install
# system deps via the playwright CLI and then fetch the chrome-for-testing build
# via @playwright/mcp's installer. We invoke the pinned bins directly (now on
# PATH) rather than `npx <pkg>`, which would resolve against /app and re-fetch
# an unpinned copy from the registry.
#
# docs/150 §8 — pin the browser to a shared path readable by both the build user
# (root) and the runtime user (`shipit`). The default install lands under
# $HOME/.cache/ms-playwright (= /root/.cache), unreachable post-`gosu`. Override
# HOME on the install-browser line too: Chrome's post-install probe writes
# prefs/font caches into $HOME/.cache. `chmod a+rX` grants read+traverse to
# `shipit` without making files world-executable. The runtime path is mirrored
# in container-lifecycle.ts (PLAYWRIGHT_BROWSERS_PATH).
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN mkdir -p /opt/playwright-browsers \
 && playwright install-deps chromium \
 && HOME=/opt/playwright-browsers playwright-mcp install-browser chrome-for-testing \
 && chmod -R a+rX /opt/playwright-browsers

# ---- Android build toolchain (docs/213) ----
# Bake the JVM + Android SDK + Gradle so the agent can build, lint, and run
# JVM/Robolectric and Paparazzi/Roborazzi snapshot tests for ANY Android/Gradle
# repo with zero per-repo setup — the same "baked, ambient" model as the agent
# CLIs and Playwright above. The toolchain is then present in every session, so a
# repo declares nothing to get a working `./gradlew` (no `shipit.yaml` Android
# fields). A repo's own Gradle/Maven deps still download per build; only the
# platform toolchain is baked. No emulator/system-image lives here — the
# running-app tier is a user-declared Compose service (docs/213), not this image.
#
# JDK 17 covers AGP 8.x (the current matrix; this repo is AGP 8.6.1 / Gradle 8.7).
# JAVA_HOME is pinned via a stable /opt/java symlink so it's arch-independent (the
# apt path is /usr/lib/jvm/java-17-openjdk-<arch>, which differs amd64 vs arm64).
RUN apt-get update && apt-get install -y openjdk-17-jdk-headless \
 && rm -rf /var/lib/apt/lists/* \
 && ln -sfn "$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")" /opt/java
ENV JAVA_HOME=/opt/java
ENV PATH="${JAVA_HOME}/bin:${PATH}"

# Android SDK: command-line tools (sdkmanager), platform-tools (adb), and a common
# compileSdk/build-tools matrix with licenses pre-accepted. Off-matrix components
# (an older platform, an NDK, CMake) are provisioned on demand via `sdkmanager`
# — see /shipit-docs/android.md. The SDK dirs are made world-writable (single
# tenant, no secrets) so those on-demand installs land under ANDROID_SDK_ROOT as
# the unprivileged `shipit` runtime user (dirs only — keeps the layer small).
ENV ANDROID_SDK_ROOT=/opt/android-sdk
ENV ANDROID_HOME=/opt/android-sdk
ENV ANDROID_CMDLINE_TOOLS_VERSION=11076708
ENV ANDROID_COMPILE_SDK=35
ENV ANDROID_BUILD_TOOLS=35.0.0
# NOTE: the archive is `commandlinetools-linux-…` (ONE word) — the hyphenated
# `commandline-tools-linux-…` is a permanent 404. `-f` makes curl FAIL on a 404
# instead of writing the HTML error page into the .zip (which then dies a step
# later at `unzip` with a misleading "End-of-central-directory" error); --retry
# rides out transient blips. Same hardening on every download below.
RUN mkdir -p "${ANDROID_SDK_ROOT}/cmdline-tools" \
 && curl -fsSL --retry 3 --retry-all-errors -o /tmp/cmdline-tools.zip \
      "https://dl.google.com/android/repository/commandlinetools-linux-${ANDROID_CMDLINE_TOOLS_VERSION}_latest.zip" \
 && unzip -q /tmp/cmdline-tools.zip -d "${ANDROID_SDK_ROOT}/cmdline-tools" \
 && mv "${ANDROID_SDK_ROOT}/cmdline-tools/cmdline-tools" "${ANDROID_SDK_ROOT}/cmdline-tools/latest" \
 && rm /tmp/cmdline-tools.zip
ENV PATH="${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin:${ANDROID_SDK_ROOT}/platform-tools:${PATH}"
RUN yes | sdkmanager --licenses > /dev/null \
 && sdkmanager --install "platform-tools" \
      "platforms;android-34" "platforms;android-${ANDROID_COMPILE_SDK}" \
      "build-tools;34.0.0" "build-tools;${ANDROID_BUILD_TOOLS}" > /dev/null \
 && find "${ANDROID_SDK_ROOT}" -type d -exec chmod a+rwx {} +

# A baked Gradle so a wrapperless repo still builds and the wrapper's first run
# resolves 8.7 fast. A committed wrapper still self-fetches its pinned dist on the
# first `./gradlew`; the agent can run the baked `gradle` to skip that one-time
# download. See /shipit-docs/android.md.
ENV GRADLE_VERSION=8.7
RUN curl -fsSL --retry 3 --retry-all-errors -o /tmp/gradle.zip "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" \
 && unzip -q /tmp/gradle.zip -d /opt \
 && ln -s "/opt/gradle-${GRADLE_VERSION}" /opt/gradle \
 && rm /tmp/gradle.zip \
 && chmod -R a+rX "/opt/gradle-${GRADLE_VERSION}"
ENV PATH="/opt/gradle/bin:${PATH}"

WORKDIR /app

# Copy pre-built node_modules from build stage (devDependencies pruned)
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./
COPY --from=build /app/tsconfig.json ./
COPY --from=build /app/src ./src
# Precompiled MCP bridge bundles (docs/199) — resolveBridge() prefers these over
# the tsx-compiled .ts source, removing the per-spawn compile cost.
COPY --from=build /app/dist/mcp-bridges ./dist/mcp-bridges

# Platform docs for the agent (accessible at /shipit-docs inside the container)
COPY src/server/shipit-docs/ /shipit-docs/

# Install the curated `gh` shim (see src/server/session/agent-shim/gh.ts).
# It's a thin Node entry point that talks to the worker's /agent-ops/* router;
# we wrap it in a small shell script so /usr/local/bin/gh behaves like a normal binary.
#
# IMPORTANT: invoke tsx via its absolute path in /app/node_modules/.bin instead of
# `node --import tsx`. The latter resolves the bare specifier `tsx` against the
# current working directory's node_modules, which fails with `Cannot find package
# 'tsx'` when the agent runs `gh` from /workspace in a user repo that doesn't
# happen to depend on tsx (i.e. almost every user repo).
RUN printf '#!/bin/sh\nexec /app/node_modules/.bin/tsx /app/src/server/session/agent-shim/gh.ts "$@"\n' > /usr/local/bin/gh \
    && chmod 0755 /usr/local/bin/gh

# Install the curated `shipit` shim (see src/server/session/agent-shim/shipit.ts).
# Mirrors the `gh` shim install above — same tsx-by-absolute-path rationale.
# The shim brokers `shipit session create/list/view` through the worker's
# /agent-ops/session/* routes (docs/117).
RUN printf '#!/bin/sh\nexec /app/node_modules/.bin/tsx /app/src/server/session/agent-shim/shipit.ts "$@"\n' > /usr/local/bin/shipit \
    && chmod 0755 /usr/local/bin/shipit

# Install the brokering `shipit-git-credential` helper (docs/088 finding #5).
# Wired into the container's gitconfig as `credential.helper`; it fetches the
# GitHub token from the worker over localhost at git-time so the PAT is never
# written into /credentials/.gitconfig. Same tsx-by-absolute-path rationale as
# the shims above.
RUN printf '#!/bin/sh\nexec /app/node_modules/.bin/tsx /app/src/server/session/agent-shim/git-credential.ts "$@"\n' > /usr/local/bin/shipit-git-credential \
    && chmod 0755 /usr/local/bin/shipit-git-credential

# Bake the agent hooks: the PreToolUse branch-block hook (docs/130) and the
# Stop-hook PR enforcement (docs/129). The settings file is referenced via
# `claude --settings <path>` from src/server/session/claude.ts — always for
# the `claude` agent, so the branch-block hook is always active.
COPY docker/agent-hooks/stop-pr-check.sh /etc/shipit/agent-hooks/stop-pr-check.sh
COPY docker/agent-hooks/block-branch-ops.mjs /etc/shipit/agent-hooks/block-branch-ops.mjs
COPY docker/agent-hooks/managed-settings.json /etc/shipit/managed-settings.json
RUN chmod 0755 /etc/shipit/agent-hooks/stop-pr-check.sh /etc/shipit/agent-hooks/block-branch-ops.mjs

# Credential symlinks (docs/150 §4 — home moved from /root to /home/shipit).
# .codex/ holds the ChatGPT subscription login written by `codex login`
# (feature 119). Persisting it on the credentials volume lets the session
# container pick up the user's subscription instead of the API key. `chown -h`
# the symlinks themselves to `shipit` so the runtime user owns the links.
RUN mkdir -p /workspace /credentials /home/shipit \
 && ln -s /credentials/.claude /home/shipit/.claude \
 && ln -sf /credentials/.claude.json /home/shipit/.claude.json \
 && ln -s /credentials/.codex /home/shipit/.codex \
 && chown -h shipit:shipit /home/shipit/.claude /home/shipit/.claude.json /home/shipit/.codex

# docs/150 — the worker's runtime HOME. AGENT_HOME is the single source of truth
# resolved by agentHome() in the worker, agent CLIs, and terminal. Set here so a
# direct `docker run` of the image (no orchestrator) still drops into the right
# home; the orchestrator also sets both in the container env. Placed AFTER all
# root build steps so npm's /root/.npm build cache mounts are unaffected.
ENV HOME=/home/shipit
ENV AGENT_HOME=/home/shipit

ENV NODE_ENV=production

EXPOSE 9100

# docs/150 §2 — root entrypoint preps writable mounts then drops to `shipit` via
# gosu. The explicit ENTRYPOINT is load-bearing: container-lifecycle.ts sets
# `Cmd: ["node", …]`, and dockerode's Cmd overrides the Dockerfile CMD but NOT
# the ENTRYPOINT — without this line the script never runs and the worker boots
# as root.
COPY docker/session-worker/entrypoint.sh /usr/local/bin/shipit-entrypoint
RUN chmod 0755 /usr/local/bin/shipit-entrypoint
ENTRYPOINT ["/usr/local/bin/shipit-entrypoint"]

CMD ["node", "--import", "tsx", "src/server/session/session-worker.ts"]
