{
  "name": "shipit",
  "version": "0.1.0",
  "description": "Browser-based AI editor for building, reviewing, and shipping software through chat.",
  "private": false,
  "license": "Apache-2.0",
  "homepage": "https://github.com/nicolasalt/shipit#readme",
  "bugs": {
    "url": "https://github.com/nicolasalt/shipit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolasalt/shipit.git"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/orchestrator/index.ts",
    "build": "vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:dev": "tsx scripts/test-dev.ts",
    "test:smoke": "tsx scripts/test-dev.ts --smoke",
    "test:watch": "vitest",
    "lint": "NODE_OPTIONS=--max-old-space-size=3072 eslint --cache --cache-location node_modules/.cache/eslint/ src/",
    "lint:dev": "tsx scripts/lint-dev.ts",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=3072 tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc/.tsbuildinfo",
    "check-deps": "tsx scripts/check-dependency-age.ts",
    "release": "tsx scripts/release.ts",
    "measure-pr-poll-cost": "tsx scripts/measure-pr-poll-cost.ts"
  },
  "dependencies": {
    "@fastify/multipart": "10.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "11.2.0",
    "@formkit/auto-animate": "0.9.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@monaco-editor/react": "4.7.0",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/typography": "0.5.19",
    "@types/better-sqlite3": "7.6.13",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "better-sqlite3": "12.6.2",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dockerode": "4.0.9",
    "fastify": "5.8.5",
    "highlight.js": "11.11.1",
    "node-pty": "1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.13.0",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "simple-git": "3.36.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "unified": "11.0.5",
    "yaml": "2.9.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.1.18",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/dockerode": "4.0.1",
    "@types/mdast": "4.0.4",
    "@types/node": "22.19.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.2",
    "globals": "17.3.0",
    "jsdom": "28.1.0",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.3",
    "vitest": "4.0.18"
  },
  "overrides": {
    "uuid": "11.1.1",
    "ws": "8.20.1",
    "protobufjs": "7.5.8",
    "@protobufjs/utf8": "1.1.1",
    "dompurify": "3.4.3",
    "fast-uri": "3.1.2",
    "postcss": "8.5.14",
    "@fastify/static": {
      "brace-expansion": "5.0.6"
    }
  }
}
