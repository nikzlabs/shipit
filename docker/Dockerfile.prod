# ---- Build stage (full image has python3/make/gcc for native addons) ----
FROM node:24-slim AS build

RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci --prefer-offline

COPY . .
RUN npm run build

# Prune devDependencies so we can copy a clean node_modules to prod
RUN --mount=type=cache,target=/root/.npm npm prune --omit=dev && npm install tsx

# ---- Production image ----
FROM node:24-slim

RUN apt-get update && apt-get install -y git curl ca-certificates gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian bookworm stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y docker-ce-cli docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.npm npm install -g @anthropic-ai/claude-code @openai/codex

WORKDIR /app

# Copy pre-built node_modules from build stage (includes compiled node-pty)
COPY --from=build /app/node_modules ./node_modules

# Copy only server source needed at runtime (no client source, tests, or docs).
# Session code runs inside per-session containers — the orchestrator only needs
# its own code and the shared layer (types, AgentRegistry, GitManager). The
# local-mode (feature 118) agent adapters live in session/ but are loaded via
# dynamic import in app-di.ts only when RUNTIME_MODE=local; that path uses the
# dev image (which bind-mounts the full repo), not this prod image.
COPY package.json package-lock.json ./
COPY tsconfig.json ./
COPY src/server/orchestrator/ ./src/server/orchestrator/
COPY src/server/shared/ ./src/server/shared/
COPY --from=build /app/dist/client ./dist/client

# Workspace for user projects — each session creates its own git repo
RUN mkdir -p /workspace /credentials && ln -s /credentials/.claude /root/.claude && ln -sf /credentials/.claude.json /root/.claude.json
VOLUME /workspace
VOLUME /credentials

ENV NODE_ENV=production

# Bake in the secrets entrypoint wrapper (087-reusable-preview-secrets,
# Phase 1 follow-up). Mounted into compose service containers at
# `/shipit/secrets-entrypoint.sh` so they can pick up Docker secrets as env
# vars without modifying user code.
COPY docker/secrets-entrypoint.sh /usr/local/share/shipit/secrets-entrypoint.sh
RUN chmod 0755 /usr/local/share/shipit/secrets-entrypoint.sh

EXPOSE 3000 5173

CMD ["node", "--import", "tsx", "src/server/orchestrator/index.ts"]
