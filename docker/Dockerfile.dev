FROM node:20-slim

RUN apt-get update && apt-get install -y git curl && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Install dependencies — source code is bind-mounted at runtime
COPY package.json package-lock.json ./
RUN npm ci

# Workspace for user projects
RUN mkdir -p /workspace && cd /workspace && git init

COPY docker/docker-entrypoint.dev.sh /usr/local/bin/

EXPOSE 3000 5173

CMD ["docker-entrypoint.dev.sh"]
