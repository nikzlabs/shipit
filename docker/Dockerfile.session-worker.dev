FROM node:24-slim@sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d

# SHI-194 — bake the pinned base-image digest into the runtime env so the overlay
# dep store keys its rolling base scope on the native-addon ABI surface, not the
# full worker-image id. The ARG default MUST track the `FROM` digest above (a base
# bump changes both together — and only that rolls the scope). See the canonical
# comment in Dockerfile.session-worker.prod.
ARG BASE_IMAGE_DIGEST=sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d
ENV BASE_IMAGE_DIGEST=${BASE_IMAGE_DIGEST}

# bubblewrap (bwrap): Codex probes for it on PATH at startup and logs an
# ERROR + configWarning when it's missing (falling back to its bundled copy).
# python3-pip + python3-venv let Python web projects (Streamlit, FastAPI, Gradio,
# Dash — see docs/168) create a venv and install deps; on Debian bookworm these
# are separate packages from python3, and PEP 668 means a global pip install is
# refused outside a venv, so a venv is the supported path.
# `gosu` (docs/150): the entrypoint drops to the unprivileged `shipit` user
# after prepping mounts. See Dockerfile.session-worker.prod for the full why.
RUN apt-get update && apt-get install -y git curl python3 python3-pip python3-venv make g++ zip unzip ripgrep bubblewrap gosu && rm -rf /var/lib/apt/lists/*

# docs/150 §1 — rename the upstream `node` user (UID/GID 1000) to `shipit`.
RUN groupmod --new-name shipit node \
 && usermod --login shipit --move-home --home /home/shipit node \
 && chown -R shipit:shipit /home/shipit

# docs/150 §6 — redirect npm's global prefix + per-user cache into the runtime
# home so `npm install -g` works as the unprivileged `shipit` user.
ENV NPM_CONFIG_PREFIX=/home/shipit/.npm-global
ENV PATH=/home/shipit/.npm-global/bin:${PATH}
RUN mkdir -p /home/shipit/.npm-global /home/shipit/.npm \
 && chown -R shipit:shipit /home/shipit/.npm-global /home/shipit/.npm

# Enable corepack so `pnpm` and `yarn` resolve on PATH. See the canonical
# comment in Dockerfile.session-worker.prod: Node ships npm + bundled corepack,
# but the pnpm/yarn shims aren't on PATH until `corepack enable` runs. corepack
# reads each repo's `packageManager` field and fetches the pinned version.
RUN corepack enable

# uv (Astral) — a single static binary that resolves/installs Python deps far
# faster than pip and reads uv.lock natively, so a repo standardized on uv "just
# works" without the agent bootstrapping a package manager. ShipIt provides the
# tool but never picks the winner: the project's lockfile decides. See docs/168.
# TODO: pin like the agent CLIs once a Renovate policy covers it.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Agent CLIs: lockfile-pinned, integrity-verified install (docs/141). See the
# canonical comment in Dockerfile.session-worker.prod. `--ignore-scripts` blocks
# the dependency tree's postinstalls; `npm rebuild @anthropic-ai/claude-code`
# runs the install script for only that trusted package (native binary linker).
COPY docker/agent-cli/package.json docker/agent-cli/package-lock.json /opt/agent-cli/
RUN --mount=type=cache,target=/root/.npm \
    (cd /opt/agent-cli && npm ci --ignore-scripts && npm rebuild @anthropic-ai/claude-code)
ENV PATH="/opt/agent-cli/node_modules/.bin:${PATH}"
RUN ln -sf /opt/agent-cli/node_modules/.bin/claude /usr/local/bin/claude \
 && ln -sf /opt/agent-cli/node_modules/.bin/codex /usr/local/bin/codex \
 && ln -sf /opt/agent-cli/node_modules/.bin/playwright-mcp /usr/local/bin/playwright-mcp

# Install Chrome and its system dependencies for Playwright MCP browser tools.
# The browser launches lazily — sessions that don't use browser tools pay zero cost.
# Playwright MCP now defaults to the `chrome-for-testing` channel, so we install
# system deps via the playwright CLI and then fetch the chrome-for-testing build
# via @playwright/mcp's installer. Invoke the pinned bins directly (on PATH)
# rather than `npx <pkg>`, which would re-fetch an unpinned copy.
# docs/150 §8 — pin browsers to a shared path readable by both build (root) and
# runtime (`shipit`) users; override HOME on install-browser for Chrome's
# post-install probe. See Dockerfile.session-worker.prod for the full rationale.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN mkdir -p /opt/playwright-browsers \
 && playwright install-deps chromium \
 && HOME=/opt/playwright-browsers playwright-mcp install-browser chrome-for-testing \
 && chmod -R a+rX /opt/playwright-browsers

# ---- Android build toolchain (docs/213) ----
# Bake the JVM + Android SDK + Gradle so the agent can build/lint/test any
# Android/Gradle repo with zero per-repo setup (the "baked, ambient" model — no
# `shipit.yaml` Android fields). See Dockerfile.session-worker.prod for the full
# rationale (JDK 17 / AGP 8.x matrix, on-demand `sdkmanager`, the /opt/java
# arch-independent symlink, world-writable SDK dirs).
RUN apt-get update && apt-get install -y openjdk-17-jdk-headless \
 && rm -rf /var/lib/apt/lists/* \
 && ln -sfn "$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")" /opt/java
ENV JAVA_HOME=/opt/java
ENV PATH="${JAVA_HOME}/bin:${PATH}"
ENV ANDROID_SDK_ROOT=/opt/android-sdk
ENV ANDROID_HOME=/opt/android-sdk
ENV ANDROID_CMDLINE_TOOLS_VERSION=11076708
ENV ANDROID_COMPILE_SDK=35
ENV ANDROID_BUILD_TOOLS=35.0.0
RUN mkdir -p "${ANDROID_SDK_ROOT}/cmdline-tools" \
 && curl -sSL -o /tmp/cmdline-tools.zip \
      "https://dl.google.com/android/repository/commandline-tools-linux-${ANDROID_CMDLINE_TOOLS_VERSION}_latest.zip" \
 && unzip -q /tmp/cmdline-tools.zip -d "${ANDROID_SDK_ROOT}/cmdline-tools" \
 && mv "${ANDROID_SDK_ROOT}/cmdline-tools/cmdline-tools" "${ANDROID_SDK_ROOT}/cmdline-tools/latest" \
 && rm /tmp/cmdline-tools.zip
ENV PATH="${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin:${ANDROID_SDK_ROOT}/platform-tools:${PATH}"
RUN yes | sdkmanager --licenses > /dev/null \
 && sdkmanager --install "platform-tools" \
      "platforms;android-34" "platforms;android-${ANDROID_COMPILE_SDK}" \
      "build-tools;34.0.0" "build-tools;${ANDROID_BUILD_TOOLS}" > /dev/null \
 && find "${ANDROID_SDK_ROOT}" -type d -exec chmod a+rwx {} +
ENV GRADLE_VERSION=8.7
RUN curl -sSL -o /tmp/gradle.zip "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" \
 && unzip -q /tmp/gradle.zip -d /opt \
 && ln -s "/opt/gradle-${GRADLE_VERSION}" /opt/gradle \
 && rm /tmp/gradle.zip \
 && chmod -R a+rX "/opt/gradle-${GRADLE_VERSION}"
ENV PATH="/opt/gradle/bin:${PATH}"

WORKDIR /app

COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci --prefer-offline --loglevel=verbose

COPY tsconfig.json ./
# Only copy code the session-worker actually needs — session + shared layers.
# Orchestrator and client code are not used and would bloat the image.
COPY src/server/session/ ./src/server/session/
COPY src/server/shared/ ./src/server/shared/

# Platform docs for the agent (accessible at /shipit-docs inside the container)
COPY src/server/shipit-docs/ /shipit-docs/

# Install the curated `gh` shim (see src/server/session/agent-shim/gh.ts).
# It's a thin Node entry point that talks to the worker's /agent-ops/* router;
# we wrap it in a small shell script so /usr/local/bin/gh behaves like a normal binary.
#
# IMPORTANT: invoke tsx via its absolute path in /app/node_modules/.bin instead of
# `node --import tsx`. The latter resolves the bare specifier `tsx` against the
# current working directory's node_modules, which fails with `Cannot find package
# 'tsx'` when the agent runs `gh` from /workspace in a user repo that doesn't
# happen to depend on tsx (i.e. almost every user repo).
RUN printf '#!/bin/sh\nexec /app/node_modules/.bin/tsx /app/src/server/session/agent-shim/gh.ts "$@"\n' > /usr/local/bin/gh \
    && chmod 0755 /usr/local/bin/gh

# Install the curated `shipit` shim (see src/server/session/agent-shim/shipit.ts).
# Mirrors the `gh` shim install above — same tsx-by-absolute-path rationale.
# The shim brokers `shipit session create/list/view` through the worker's
# /agent-ops/session/* routes (docs/117).
RUN printf '#!/bin/sh\nexec /app/node_modules/.bin/tsx /app/src/server/session/agent-shim/shipit.ts "$@"\n' > /usr/local/bin/shipit \
    && chmod 0755 /usr/local/bin/shipit

# Install the brokering `shipit-git-credential` helper (docs/088 finding #5).
# Wired into the container's gitconfig as `credential.helper`; it fetches the
# GitHub token from the worker over localhost at git-time so the PAT is never
# written into /credentials/.gitconfig. Same tsx-by-absolute-path rationale.
RUN printf '#!/bin/sh\nexec /app/node_modules/.bin/tsx /app/src/server/session/agent-shim/git-credential.ts "$@"\n' > /usr/local/bin/shipit-git-credential \
    && chmod 0755 /usr/local/bin/shipit-git-credential

# Bake the agent hooks: the PreToolUse branch-block hook (docs/130) and the
# Stop-hook PR enforcement (docs/129). The settings file is referenced via
# `claude --settings <path>` from src/server/session/claude.ts — always for
# the `claude` agent, so the branch-block hook is always active.
COPY docker/agent-hooks/stop-pr-check.sh /etc/shipit/agent-hooks/stop-pr-check.sh
COPY docker/agent-hooks/block-branch-ops.mjs /etc/shipit/agent-hooks/block-branch-ops.mjs
COPY docker/agent-hooks/managed-settings.json /etc/shipit/managed-settings.json
RUN chmod 0755 /etc/shipit/agent-hooks/stop-pr-check.sh /etc/shipit/agent-hooks/block-branch-ops.mjs

# Credential symlinks (docs/150 §4 — home moved from /root to /home/shipit).
# .codex/ holds the ChatGPT subscription login written by `codex login`
# (feature 119). Persisting it on the credentials volume lets the session
# container pick up the user's subscription instead of the API key.
RUN mkdir -p /workspace /credentials /home/shipit \
 && ln -s /credentials/.claude /home/shipit/.claude \
 && ln -sf /credentials/.claude.json /home/shipit/.claude.json \
 && ln -s /credentials/.codex /home/shipit/.codex \
 && chown -h shipit:shipit /home/shipit/.claude /home/shipit/.claude.json /home/shipit/.codex

# docs/150 — runtime HOME / AGENT_HOME (single source of truth for agentHome()).
# Placed after all root build steps so /root/.npm build caches are unaffected.
ENV HOME=/home/shipit
ENV AGENT_HOME=/home/shipit

EXPOSE 9100

# docs/150 §2 — root entrypoint preps mounts then drops to `shipit` via gosu.
# The explicit ENTRYPOINT is load-bearing (dockerode Cmd overrides CMD, not
# ENTRYPOINT). See Dockerfile.session-worker.prod.
COPY docker/session-worker/entrypoint.sh /usr/local/bin/shipit-entrypoint
RUN chmod 0755 /usr/local/bin/shipit-entrypoint
ENTRYPOINT ["/usr/local/bin/shipit-entrypoint"]

CMD ["node", "--import", "tsx", "src/server/session/session-worker.ts"]
