<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground. Drawn on a 108x108dp canvas; the inner 72x72dp
  is the safe zone (corners get masked by the launcher).

  This is a simplified "rocket" silhouette inspired by the favicon — flat
  colors only, no gradients (Android vector drawables don't support all SVG
  features). Replace with a polished asset before publishing to Play Store.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Body of the rocket, centered in the 72dp safe zone -->
    <path
        android:fillColor="#E94560"
        android:pathData="M54 30
            C54 30 46 42 45 56
            L45 76
            Q45 80 49 81
            L51 82
            L51 86
            L57 86
            L57 82
            L59 81
            Q63 80 63 76
            L63 56
            C62 42 54 30 54 30 Z" />

    <!-- Left fin -->
    <path
        android:fillColor="#C23152"
        android:pathData="M45 72 L37 84 L37 86 Q39 85 45 80 Z" />

    <!-- Right fin -->
    <path
        android:fillColor="#C23152"
        android:pathData="M63 72 L71 84 L71 86 Q69 85 63 80 Z" />

    <!-- Window -->
    <path
        android:fillColor="#A8D8EA"
        android:pathData="M54 54 m-6 0 a6 6 0 1 0 12 0 a6 6 0 1 0 -12 0" />

    <!-- Flame -->
    <path
        android:fillColor="#F7C948"
        android:pathData="M54 86 L50 92 Q54 96 54 96 Q54 96 58 92 Z" />
</vector>
