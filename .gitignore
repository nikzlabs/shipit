node_modules/
dist/
.shipit/
.env
*.log
*.db
*.db-wal
*.db-shm
.update-requested
.restart-requested
# Release-channel preference (feature 162). Untracked so it survives
# `git reset --hard` and image rebuilds.
.release-channel
.shipit

# Playwright MCP browser-driven debugging output (snapshots, console logs)
.playwright-mcp/

# Claude Code local runtime state (scheduled-task locks, etc.)
.claude/scheduled_tasks.lock

# ShipIt-in-ShipIt (feature 118 — dogfooding mode).
# When the orchestrator runs with RUNTIME_MODE=local inside a ShipIt session,
# inner-session clones land under `sessions/` and the inner orch's state
# (SQLite db, repo-cache, dep-cache) lives under `.inner-shipit/`. Excluding
# both prevents the outer auto-commit (`git add -A`) from picking them up as
# embedded gitlinks (mode 160000) or committing inner-orch metadata.
sessions/
.inner-shipit/

# Android (see android/ — separate Gradle build, not part of the Node project)
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/
android/.cxx/
*.keystore
*.jks
