# Pin every `npm install <pkg>` to an exact version (no ^/~ ranges). Backs the
# "exact pins" half of the dependency policy (CLAUDE.md); scripts/check-dependency-age.ts
# enforces it in CI.
save-exact=true

# Supply-chain age gate (npm >= 11.10, Node 24 — which this repo requires).
# npm won't *resolve* a version published less than 7 days ago, so a fresh
# `npm install <pkg>` / `npm update` / lockfile regen can't pull a just-published
# (possibly compromised) release. This enforces the age half of the dependency
# policy proactively at install time, complementing the CI check-deps gate and
# Dependabot's 7-day cooldown. Keep in sync with MIN_AGE_DAYS in
# scripts/check-dependency-age.ts and `cooldown.default-days` in
# .github/dependabot.yml.
#
# Note: `npm ci` installs the lockfile verbatim and is NOT gated, so CI/Docker
# reproducible installs are unaffected — the gate only bites when resolving new
# versions. For a genuine same-day security fix, override per-invocation with
# `npm install <pkg> --min-release-age=0` and call it out in the PR (per policy).
min-release-age=7