# ShipIt-in-ShipIt dogfooding image (feature 118).
#
# Minimal image for the `dev` Compose service: a Node runtime plus the agent
# CLIs. It no longer pre-bakes node_modules — the `dev` service now shares the
# agent container's bind-mounted /workspace/node_modules (populated by
# `agent.install`) instead of carrying its own copy. See the volumes/command
# notes in docker-compose.yml, and feature 137 (docs/137-depends-on-install)
# for the broader "share the install output instead of racing it" rationale,
# for why the separate tree and the in-command `npm install` were removed.
#
# Node version is pinned to the SAME node:24-slim digest as the agent /
# session-worker prod image. This is load-bearing:
# the native modules in node_modules (better-sqlite3, node-pty, …) are built by
# `agent.install` inside the node:24 agent container, and the `dev` service must
# share that ABI to load them. (Previously this image was node:22 with its own
# node_modules; that split is gone now that the tree is shared.)

FROM node:24-slim@sha256:4e6b70dd6cbfc88c8157ba19aa3d9f9cce6ba4703576d55459e45efcbc9c5f5d

WORKDIR /workspace

# Runtime tools the inner orchestrator needs. The previous full `node:22` base
# bundled git; `node:24-slim` does not, so install it explicitly along with the
# same toolset baked into the session-worker runtime image
# (Dockerfile.session-worker.prod). git is load-bearing — the inner
# orch's GitManager shells out to it for clone/commit/diff. The others keep the
# inner orch's behavior at parity with a real session container.
RUN apt-get update \
    && apt-get install -y git curl python3 make g++ zip unzip ripgrep bubblewrap \
    && rm -rf /var/lib/apt/lists/*

# Install the agent CLIs so the inner orchestrator (RUNTIME_MODE=local) can
# spawn them in-process via claude-adapter / codex-adapter. The shared
# AgentRegistry detects agents with `which <binary>`, so without these on PATH
# the inner UI shows "Not installed" on the Agent Setup screen and no session
# can start. Lockfile-pinned, integrity-verified install shared with the worker
# images (docs/141); canonical comment in Dockerfile.session-worker.prod.
# `--ignore-scripts` blocks the dependency tree's postinstalls; `npm rebuild
# @anthropic-ai/claude-code` runs the install script for only that trusted
# package (native binary linker), placing its bin on PATH alongside codex /
# playwright-mcp.
COPY docker/agent-cli/package.json docker/agent-cli/package-lock.json /opt/agent-cli/
RUN --mount=type=cache,target=/root/.npm \
    (cd /opt/agent-cli && npm ci --ignore-scripts && npm rebuild @anthropic-ai/claude-code)
ENV PATH="/opt/agent-cli/node_modules/.bin:${PATH}"
RUN ln -sf /opt/agent-cli/node_modules/.bin/claude /usr/local/bin/claude \
 && ln -sf /opt/agent-cli/node_modules/.bin/codex /usr/local/bin/codex \
 && ln -sf /opt/agent-cli/node_modules/.bin/playwright-mcp /usr/local/bin/playwright-mcp

# No-op git credential helper. Session workspaces carry a local
# `credential.helper = /usr/local/bin/shipit-git-credential` (the brokering
# binary, installed only in the session-worker images). When the orchestrator —
# or, in local mode (RUNTIME_MODE=local), the in-process agent — runs git
# against such a workspace, git answers `get` from the global inline helper but
# still calls the local broker for `store`/`erase`; without the binary that
# fails with "shipit-git-credential: not found" (docs/192). This silent no-op
# absorbs those calls so the global helper stays the sole credential source.
RUN printf '#!/bin/sh\nexec cat >/dev/null 2>&1\n' > /usr/local/bin/shipit-git-credential \
 && chmod 0755 /usr/local/bin/shipit-git-credential

# docs/150 §9 — local mode (RUNTIME_MODE=local) keeps the orchestrator on root.
# It hosts the agent processes in-process (claude-adapter / codex-adapter), which
# resolve their HOME via agentHome(). Since DEFAULT_AGENT_HOME is /home/shipit,
# we MUST pin AGENT_HOME=/root here (no `shipit` user exists in this image) or
# the agent CLIs would read credentials from a non-existent home and auth would
# break. The non-root hardening intentionally does not apply to dogfood/local
# mode — see docs/118-shipit-ui-local/plan.md.
ENV HOME=/root
ENV AGENT_HOME=/root
