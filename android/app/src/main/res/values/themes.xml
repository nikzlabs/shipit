<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ShipIt" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/shipit_accent</item>
        <item name="colorPrimaryDark">@color/shipit_bg</item>
        <item name="colorAccent">@color/shipit_accent</item>
        <item name="android:colorBackground">@color/shipit_bg</item>
        <item name="android:windowBackground">@color/shipit_bg</item>
        <!-- targetSdk 35 (Android 15) enforces edge-to-edge and IGNORES
             android:statusBarColor / android:navigationBarColor, so those are
             gone. The bars are transparent; the dark windowBackground above
             shows through them, keeping the full-bleed look. We still ask for
             light (white) status-bar icons since that background is dark. -->
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

</resources>
