FROM node:24-slim

RUN apt-get update && apt-get install -y git curl python3 make g++ docker-compose-plugin && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code @openai/codex

WORKDIR /app

# Install dependencies — source code is bind-mounted at runtime
COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci --prefer-offline --loglevel=verbose

# Workspace for user projects — each session creates its own git repo
RUN mkdir -p /workspace /credentials && ln -s /credentials/.claude /root/.claude && ln -sf /credentials/.claude.json /root/.claude.json
VOLUME /workspace
VOLUME /credentials

COPY docker/docker-entrypoint.dev.sh /usr/local/bin/

EXPOSE 3000 5173

CMD ["docker-entrypoint.dev.sh"]
